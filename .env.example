# Public — exposed to the browser. Get these from Supabase Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Secret — server-only, NEVER prefix with NEXT_PUBLIC_. From Project Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Secret — the password the hidden admin button asks for.
ADMIN_PASSWORD=ganti-password-ini

# Secret — random long string used to sign the admin session cookie.
ADMIN_SESSION_SECRET=ganti-dengan-string-acak-panjang

# Name of the public Supabase Storage bucket used for presentation files.
NEXT_PUBLIC_STORAGE_BUCKET=presentations
